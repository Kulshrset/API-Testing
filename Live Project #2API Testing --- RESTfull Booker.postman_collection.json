  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level Error Handling and Validation",
          "pm.test(\"Global Error Handling - Network Errors\", function () {",
          "    pm.expect(pm.response.reason).to.not.include('network');",
          "});",
          "",
          "pm.test(\"Global Response Validation - Content Type\", function () {",
          "    pm.response.to.have.header('Content-Type', 'application/json; charset=utf-8');",
          "});",
          "",
          "pm.test(\"Global Error Handling - Rate Limiting\", function () {",
          "    if (pm.response.code === 429) {",
          "        pm.expect(pm.response.headers.get('Retry-After')).to.exist;",
          "    }",
          "});"
        ]
      }
    },
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level Pre-request Setup",
          "// Ensure authentication and environment variables are set up before requests",
          "if (!pm.environment.get('authToken')) {",
          "    // Trigger authentication if token is not present",
          "    const authRequest = {",
          "        url: pm.environment.get('baseUrl') + '/auth',",
          "        method: 'POST',",
          "        header: {'Content-Type': 'application/json'},",
          "        body: {",
          "            mode: 'raw',",
          "            raw: JSON.stringify({",
          "                username: pm.environment.get('username'),",
          "                password: pm.environment.get('password')",
          "            })",
          "        }",
          "    };",
          "    ",
          "    pm.sendRequest(authRequest, (error, response) => {",
          "        if (error) {",
          "            console.error(error);",
          "        } else {",
          "            const jsonResponse = response.json();",
          "            pm.environment.set('authToken', jsonResponse.token);",
          "        }",
          "    });",
          "}",
          "",
          "// Set default headers for all requests",
          "pm.request.headers.add({",
          "    key: 'Accept',",
          "    value: 'application/json'",
          "});",
          "",
          "// Add authorization header if token exists",
          "if (pm.environment.get('authToken')) {",
          "    pm.request.headers.add({",
          "        key: 'Authorization',",
          "        value: 'Bearer ' + pm.environment.get('authToken')",
          "    });",
          "}"
        ]
      }
    }
